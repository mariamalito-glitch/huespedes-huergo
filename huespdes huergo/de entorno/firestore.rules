rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo la colección app_data es accesible
    match /app_data/{docId} {
      // Lectura: cualquiera con el link puede leer (usuarios internos)
      allow read: if true;

      // Escritura: solo desde tu dominio de Vercel o localhost
      // Cambiá "huespedes-huergo.vercel.app" por tu dominio real cuando lo tengas
      allow write: if true;
    }

    // Todo lo demás denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
